---
// CRT screen "frame" - uneven backlight + curvature feel.
// Asymmetric corner glows (amber top-right, green bottom-left) like creator.sdet.it.
// Strong dark vignette suggests curved tube glass.
---

<div class="crt-frame" aria-hidden="true"></div>

<style is:global>
  .crt-frame {
    position: fixed;
    inset: 0;
    z-index: 9995;
    pointer-events: none;
    display: none;
    background:
      /* Uneven backlight - amber top-right corner */
      radial-gradient(ellipse 70% 50% at 95% 5%, rgba(255, 176, 0, 0.07), transparent 55%),
      /* Uneven backlight - green bottom-left corner */
      radial-gradient(ellipse 65% 45% at 5% 95%, rgba(0, 255, 65, 0.06), transparent 50%),
      /* Subtle phosphor glow center */
      radial-gradient(ellipse 80% 60% at 50% 50%, rgba(0, 255, 65, 0.02), transparent 60%),
      /* Main vignette - curved tube edges */
      radial-gradient(ellipse 90% 90% at 50% 50%, transparent 35%, rgba(0, 0, 0, 0.55) 88%, rgba(0, 0, 0, 0.85) 100%);
  }

  [data-cyber-bg='a'] .crt-frame { display: block; opacity: 1; }
  [data-cyber-bg='b'] .crt-frame {
    display: block;
    opacity: 1;
    background:
      radial-gradient(ellipse 70% 50% at 95% 5%, rgba(255, 176, 0, 0.12), transparent 55%),
      radial-gradient(ellipse 65% 45% at 5% 95%, rgba(0, 255, 65, 0.1), transparent 50%),
      radial-gradient(ellipse 80% 60% at 50% 50%, rgba(0, 255, 65, 0.04), transparent 60%),
      radial-gradient(ellipse 88% 88% at 50% 50%, transparent 28%, rgba(0, 0, 0, 0.78) 88%, rgba(0, 0, 0, 0.95) 100%);
  }
  [data-cyber-bg='c'][data-page-type='home'] .crt-frame { display: block; opacity: 1; }
  [data-cyber-bg='d'] .crt-frame { display: block; opacity: 0.85; }
</style>
