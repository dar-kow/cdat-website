---
// CRT vertical retrace beam - single soft horizontal scanline drifting
// top→bottom. Color hue shifts with vertical position (cyan-green at top,
// pure green mid, amber-green at bottom - like phosphor response varying
// across the screen). Random timing + occasional micro-freezes + tiny
// jitter + rare opacity wink.
---

<div class="crt-moving-scanline" aria-hidden="true"></div>

<style is:global>
  .crt-moving-scanline {
    --beam-hue: 130;
    --beam-alpha-core: 0.16;
    --beam-alpha-edge: 0.04;
    position: fixed;
    left: 0;
    right: 0;
    top: 0;
    height: 80px;
    z-index: 9992;
    pointer-events: none;
    display: none;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      hsla(var(--beam-hue), 95%, 55%, var(--beam-alpha-edge)) 35%,
      hsla(var(--beam-hue), 95%, 55%, var(--beam-alpha-core)) 50%,
      hsla(var(--beam-hue), 95%, 55%, var(--beam-alpha-edge)) 65%,
      transparent 100%
    );
    transform: translate3d(0, -100px, 0);
    will-change: transform, opacity;
    transition: opacity 90ms ease;
  }

  [data-cyber-bg='a'] .crt-moving-scanline { display: block; }
  [data-cyber-bg='b'] .crt-moving-scanline {
    display: block;
    height: 110px;
    --beam-alpha-core: 0.22;
    --beam-alpha-edge: 0.06;
  }
  [data-cyber-bg='c'][data-page-type='home'] .crt-moving-scanline { display: block; }
  [data-cyber-bg='d'] .crt-moving-scanline { display: block; }
</style>

<script is:inline>
  (function () {
    var prm = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prm) return;

    var el = null;
    function getEl() {
      if (!el) el = document.querySelector('.crt-moving-scanline');
      return el;
    }

    var idleTimer = null;
    var winking = false;

    function rand(a, b) { return a + Math.random() * (b - a); }

    // Hue curve: top → cyan-green (165), middle → pure green (130),
    // bottom → amber-green (75). Travels through the phosphor temperature
    // range a real CRT would render the beam in.
    function hueAt(p) {
      if (p < 0.5) return 165 - p * 70;       // 165 → 130
      return 130 - (p - 0.5) * 110;            // 130 → 75
    }

    function maybeWink(node) {
      if (winking) return;
      if (Math.random() < 0.0017) {
        winking = true;
        node.style.opacity = String(rand(0.18, 0.35));
        setTimeout(function () {
          node.style.opacity = '';
          winking = false;
        }, 80 + Math.floor(rand(40, 80)));
      }
    }

    function runOnce() {
      var node = getEl();
      if (!node) return;
      var cs = window.getComputedStyle(node);
      if (cs.display === 'none') {
        idleTimer = setTimeout(runOnce, 800);
        return;
      }
      var vh = window.innerHeight + 100;
      var startY = -100;
      var startT = performance.now();
      var dur = rand(7000, 12000);
      var freezeAt = Math.random() < 0.65 ? rand(0.3, 0.75) : -1;
      var freezeDur = rand(180, 380);
      var jitterMag = rand(1, 3);
      var froze = false;

      function step(t) {
        var p = (t - startT) / dur;
        if (p >= 1) {
          var idle = rand(2500, 6500);
          idleTimer = setTimeout(runOnce, idle);
          return;
        }
        if (freezeAt > 0 && !froze && p > freezeAt) {
          froze = true;
          var holdY = startY + (vh - startY) * p;
          node.style.setProperty('--beam-hue', hueAt(p).toFixed(0));
          node.style.transform =
            'translate3d(' + Math.round(rand(-jitterMag, jitterMag)) + 'px, ' +
            Math.round(holdY + rand(-jitterMag, jitterMag)) + 'px, 0)';
          setTimeout(function () {
            requestAnimationFrame(step);
          }, freezeDur);
          return;
        }
        var y = startY + (vh - startY) * p;
        var jx = Math.round(rand(-jitterMag, jitterMag));
        node.style.setProperty('--beam-hue', hueAt(p).toFixed(0));
        node.style.transform = 'translate3d(' + jx + 'px, ' + Math.round(y) + 'px, 0)';
        maybeWink(node);
        requestAnimationFrame(step);
      }

      requestAnimationFrame(step);
    }

    function init() {
      idleTimer = setTimeout(runOnce, 3500);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
