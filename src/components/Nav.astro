---
const links = [
  { href: '/docs', label: 'Docs' },
  { href: '/examples', label: 'Examples' },
  { href: '/resources', label: 'Resources' },
  { href: '/about', label: 'About' },
];
const current = Astro.url.pathname;
---
<header class="sticky top-0 z-40 border-b border-primary-900 bg-gray-900/95 backdrop-blur">
  <nav aria-label="Primary" class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3 font-mono text-sm">
    <a href="/" class="text-primary-500 no-underline hover:text-primary-300" aria-label="CDAT Pattern home">
      <span aria-hidden="true">&gt;</span> <strong>cdat</strong>
    </a>
    <ul class="flex items-center gap-4">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class={`no-underline ${current.startsWith(href) ? 'text-accent-500' : 'text-primary-500 hover:text-primary-300'}`}
            aria-current={current.startsWith(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="https://github.com/dar-kow/cdat-pattern"
          class="text-primary-700 hover:text-primary-300 no-underline"
          rel="noopener"
        >
          GitHub ↗
        </a>
      </li>
    </ul>
  </nav>
</header>
