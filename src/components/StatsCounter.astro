---
// StatsCounter.astro - IntersectionObserver-triggered count-up, once-only.
// "months in production" target recomputes at each build via cdat-tenure.
import { productionMonths } from '../lib/cdat-tenure';

const stats = [
  { label: 'production systems', target: 9, suffix: '' },
  { label: 'months in production', target: productionMonths, suffix: '' },
  { label: 'hardcoded waits', target: 0, suffix: '' },
] as const;
---
<section class="stats-counter" aria-label="CDAT production stats">
  <ul>
    {stats.map((s) => (
      <li>
        <span class="value" data-target={s.target} aria-live="polite">0{s.suffix}</span>
        <span class="label">{s.label}</span>
      </li>
    ))}
  </ul>
</section>

<style>
  /* Full-width band under hero (mirrors sdet.it stats layout). */
  .stats-counter {
    padding: 3rem 1rem;
    border-top: 1px solid var(--color-primary-900);
    border-bottom: 1px solid var(--color-primary-900);
    background: rgba(0, 255, 65, 0.02);
  }
  .stats-counter ul {
    list-style: none;
    padding: 0;
    margin: 0 auto;
    max-width: var(--max-w);
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 640px) {
    .stats-counter ul { grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  }
  .stats-counter li {
    text-align: center;
    font-family: var(--font-mono);
    position: relative;
    padding: 0.5rem 1rem;
  }
  /* Subtle marker dot - phosphor green, 40% opacity, top-right (mirrors sdet.it). */
  .stats-counter li::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0.5rem;
    width: 6px;
    height: 6px;
    background: var(--color-primary-500);
    opacity: 0.4;
  }
  .stats-counter .value {
    display: block;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-accent-500);
    line-height: 1;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
  }
  .stats-counter .label {
    display: block;
    color: var(--color-gray-500);
    font-size: 0.875rem;
    text-transform: lowercase;
    letter-spacing: 0.04em;
    margin-top: 0.5rem;
  }
</style>

<script>
  type ValueSpan = HTMLSpanElement & { dataset: { target: string; done?: string } };

  const REDUCED = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const DURATION_MS = 1500;

  function easeOut(t: number): number {
    return 1 - Math.pow(1 - t, 3);
  }

  function animate(el: ValueSpan): void {
    if (el.dataset.done === '1') return;
    el.dataset.done = '1';
    const target = Number(el.dataset.target);
    if (REDUCED || !Number.isFinite(target)) {
      el.textContent = String(target);
      return;
    }
    const start = performance.now();
    function tick(now: number): void {
      const t = Math.min(1, (now - start) / DURATION_MS);
      const v = Math.round(target * easeOut(t));
      el.textContent = String(v);
      if (t < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  const els = document.querySelectorAll<ValueSpan>('.stats-counter .value');

  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;
        animate(entry.target as ValueSpan);
        io.unobserve(entry.target);
      }
    }, { threshold: 0.5 });
    els.forEach((el) => io.observe(el));
  } else {
    els.forEach((el) => animate(el));
  }
</script>
