---
import { getCollection } from 'astro:content';

interface Props {
  activeId?: string;
}
const { activeId } = Astro.props;
const all = await getCollection('docs');
const docs = all.sort((a, b) => a.data.order - b.data.order);
---
<aside class="docs-sidebar" aria-label="Documentation navigation">
  <nav>
    <h2>Docs</h2>
    <ul role="list">
      {docs.map((d) => (
        <li>
          <a
            href={`/docs/${d.id}`}
            class:list={['docs-nav-link', { active: d.id === activeId }]}
            aria-current={d.id === activeId ? 'page' : undefined}
          >
            {d.data.title}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</aside>

<style>
  .docs-sidebar {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    padding: 1.5rem 1rem;
  }
  .docs-sidebar h2 {
    color: var(--color-primary-500);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.75rem;
    margin: 0 0 0.75rem;
  }
  .docs-sidebar ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.25rem;
  }
  .docs-nav-link {
    display: block;
    padding: 0.5rem 0.75rem;
    color: #cfd8d4;
    text-decoration: none;
    border-left: 2px solid transparent;
    border-radius: 0 4px 4px 0;
  }
  .docs-nav-link:hover {
    color: var(--color-primary-300);
    background: rgba(0, 255, 65, 0.04);
  }
  .docs-nav-link.active {
    color: var(--color-accent-500);
    border-left-color: var(--color-accent-500);
    background: rgba(255, 176, 0, 0.06);
  }
  .docs-nav-link:focus-visible {
    outline: 2px solid var(--color-accent-500);
    outline-offset: 2px;
  }
</style>
