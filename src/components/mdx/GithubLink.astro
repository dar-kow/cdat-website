---
interface Props {
  path?: string;
  label?: string;
}
const { path = '', label = 'Read raw source on GitHub' } = Astro.props;
const cleanPath = path.replace(/^\/+/, '');
const url = cleanPath
  ? `https://github.com/darco81/cdat-pattern/blob/main/${cleanPath}`
  : 'https://github.com/darco81/cdat-pattern';
---
<p class="gh-link">
  <a href={url} target="_blank" rel="noopener" data-plausible-event="cdat_github_external_click" data-location="docs">
    {label} ↗
  </a>
</p>

<style>
  .gh-link {
    margin: 2rem 0 1rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    border-top: 1px solid var(--color-primary-900);
    padding-top: 1rem;
  }
  .gh-link a { color: var(--color-accent-500); }
</style>
