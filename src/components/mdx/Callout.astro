---
interface Props {
  type?: 'info' | 'warn' | 'tip' | 'danger';
  title?: string;
}
const { type = 'info', title } = Astro.props;
const icon = { info: 'ℹ️', warn: '⚠️', tip: '💡', danger: '🚨' }[type];
---
<aside class:list={['callout', `callout-${type}`]} role="note">
  <p class="callout-title">{icon} {title ?? type.toUpperCase()}</p>
  <div class="callout-body"><slot /></div>
</aside>

<style>
  .callout {
    border-left: 4px solid var(--color-primary-500);
    background: rgba(0, 255, 65, 0.04);
    padding: 0.75rem 1rem;
    border-radius: 0 6px 6px 0;
    margin: 1.5rem 0;
    font-family: var(--font-sans);
    font-size: 0.95rem;
  }
  .callout-warn   { border-left-color: var(--color-accent-500); background: rgba(255, 176, 0, 0.06); }
  .callout-tip    { border-left-color: #4dffa3; }
  .callout-danger { border-left-color: #ef4444; background: rgba(239, 68, 68, 0.06); }

  .callout-title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary-300);
    margin: 0 0 0.5rem;
  }
  .callout-warn .callout-title { color: var(--color-accent-500); }
  .callout-danger .callout-title { color: #fca5a5; }
  .callout-body :global(p) { margin: 0.25rem 0; }
</style>
