---
// CdatDiagram.astro — animated 4-layer SVG (Components/Data → Actions → Tests).
// Pure SVG inline, CSS-only animations, prefers-reduced-motion guarded.
---
<svg
  class="cdat-diagram"
  viewBox="0 0 800 560"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-labelledby="cdat-diagram-title cdat-diagram-desc"
>
  <title id="cdat-diagram-title">CDAT 4-layer dependency diagram</title>
  <desc id="cdat-diagram-desc">
    Components and Data feed Actions, which combine with Components and Data
    to feed Tests. Arrows show dependency direction.
  </desc>

  <defs>
    <marker id="arrowhead" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M 0 0 L 10 5 L 0 10 z" fill="currentColor" />
    </marker>
  </defs>

  <g class="boxes" stroke="currentColor" stroke-width="3">
    <g class="box box-components">
      <rect x="60" y="30" width="240" height="100" rx="8" fill="rgba(0, 0, 0, 0.7)" />
      <text x="180" y="72" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="26" font-weight="700" fill="currentColor" stroke="currentColor" stroke-width="0.6" paint-order="stroke fill">Components</text>
      <text x="180" y="106" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="20" font-weight="700" fill="currentColor" stroke="currentColor" stroke-width="0.5" paint-order="stroke fill">locators only</text>
    </g>

    <g class="box box-data">
      <rect x="500" y="30" width="240" height="100" rx="8" fill="rgba(0, 0, 0, 0.7)" />
      <text x="620" y="72" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="26" font-weight="700" fill="currentColor" stroke="currentColor" stroke-width="0.6" paint-order="stroke fill">Data</text>
      <text x="620" y="106" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="20" font-weight="700" fill="currentColor" stroke="currentColor" stroke-width="0.5" paint-order="stroke fill">types · fixtures</text>
    </g>

    <g class="box box-actions">
      <rect x="280" y="230" width="240" height="100" rx="8" fill="rgba(0, 0, 0, 0.7)" />
      <text x="400" y="272" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="26" font-weight="700" fill="currentColor" stroke="currentColor" stroke-width="0.6" paint-order="stroke fill">Actions</text>
      <text x="400" y="306" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="20" font-weight="700" fill="currentColor" stroke="currentColor" stroke-width="0.5" paint-order="stroke fill">business logic</text>
    </g>

    <g class="box box-tests">
      <rect x="280" y="430" width="240" height="100" rx="8" fill="rgba(0, 0, 0, 0.7)" />
      <text x="400" y="462" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="26" font-weight="700" fill="currentColor" stroke="currentColor" stroke-width="0.6" paint-order="stroke fill">Tests</text>
      <text x="400" y="490" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="18" font-weight="700" fill="currentColor" stroke="currentColor" stroke-width="0.5" paint-order="stroke fill">
        <tspan x="400">scenarios</tspan>
        <tspan x="400" dy="22">assertions</tspan>
      </text>
    </g>
  </g>

  <g class="arrows" stroke="currentColor" stroke-width="2" fill="none" marker-end="url(#arrowhead)">
    <path d="M 220 130 L 360 230" />
    <path d="M 580 130 L 440 230" />
    <path d="M 400 330 L 400 430" />
    <path d="M 180 130 C 180 280, 250 430, 290 470" />
    <path d="M 620 130 C 620 280, 550 430, 510 470" />
  </g>
</svg>

<style>
  .cdat-diagram {
    color: var(--color-primary-500);
    width: 100%;
    height: auto;
    max-width: 720px;
    margin: 0 auto;
    display: block;
    text-rendering: geometricPrecision;
    shape-rendering: geometricPrecision;
  }

  /* Static phosphor glow on labels — sharp text + subtle radiance. */
  .cdat-diagram text {
    paint-order: stroke fill;
    /* SVG can't accept text-shadow via CSS reliably across browsers; rely on
       the diagram's overall feel. Filter on root would blur — avoid. */
  }

  .cdat-diagram .arrows path {
    stroke-dasharray: 6 6;
    animation: arrow-flow 3s linear infinite;
  }

  @keyframes arrow-flow {
    to { stroke-dashoffset: -24; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cdat-diagram .arrows path {
      animation: none !important;
    }
  }
</style>
