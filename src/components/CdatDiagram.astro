---
// CdatDiagram.astro — animated 4-layer SVG (Components/Data → Actions → Tests).
// Pure SVG inline, CSS-only animations, prefers-reduced-motion guarded.
---
<svg
  class="cdat-diagram"
  viewBox="0 0 800 500"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-labelledby="cdat-diagram-title cdat-diagram-desc"
>
  <title id="cdat-diagram-title">CDAT 4-layer dependency diagram</title>
  <desc id="cdat-diagram-desc">
    Components and Data feed Actions, which combine with Components and Data
    to feed Tests. Arrows show dependency direction.
  </desc>

  <defs>
    <marker id="arrowhead" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M 0 0 L 10 5 L 0 10 z" fill="currentColor" />
    </marker>
  </defs>

  <g class="boxes" stroke="currentColor" stroke-width="2" fill="rgba(0,255,65,0.04)">
    <g class="box box-components">
      <rect x="60" y="30" width="240" height="100" rx="8" />
      <text x="180" y="78" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="22" font-weight="700" fill="currentColor">Components</text>
      <text x="180" y="108" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="14" fill="currentColor" opacity="0.7">locators only</text>
    </g>

    <g class="box box-data">
      <rect x="500" y="30" width="240" height="100" rx="8" />
      <text x="620" y="78" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="22" font-weight="700" fill="currentColor">Data</text>
      <text x="620" y="108" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="14" fill="currentColor" opacity="0.7">types · fixtures</text>
    </g>

    <g class="box box-actions">
      <rect x="280" y="200" width="240" height="100" rx="8" />
      <text x="400" y="248" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="22" font-weight="700" fill="currentColor">Actions</text>
      <text x="400" y="278" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="14" fill="currentColor" opacity="0.7">business logic</text>
    </g>

    <g class="box box-tests">
      <rect x="280" y="370" width="240" height="100" rx="8" />
      <text x="400" y="418" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="22" font-weight="700" fill="currentColor">Tests</text>
      <text x="400" y="448" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="14" fill="currentColor" opacity="0.7">scenarios · assertions</text>
    </g>
  </g>

  <g class="arrows" stroke="currentColor" stroke-width="2" fill="none" marker-end="url(#arrowhead)">
    <path d="M 220 130 L 360 200" />
    <path d="M 580 130 L 440 200" />
    <path d="M 400 300 L 400 370" />
    <path d="M 180 130 C 180 250, 250 370, 290 410" />
    <path d="M 620 130 C 620 250, 550 370, 510 410" />
  </g>
</svg>

<style>
  .cdat-diagram {
    color: var(--color-primary-500);
    width: 100%;
    height: auto;
    max-width: 720px;
    margin: 0 auto;
    display: block;
  }

  .cdat-diagram .box rect {
    transform-box: fill-box;
    transform-origin: center;
    animation: phosphor-pulse 2s ease-in-out infinite;
    filter: drop-shadow(0 0 6px rgba(0, 255, 65, 0.35));
  }

  .cdat-diagram .box-components rect { animation-delay: 0s; }
  .cdat-diagram .box-data       rect { animation-delay: 0.5s; }
  .cdat-diagram .box-actions    rect { animation-delay: 1s; }
  .cdat-diagram .box-tests      rect { animation-delay: 1.5s; }

  .cdat-diagram .arrows path {
    stroke-dasharray: 6 6;
    animation: arrow-flow 3s linear infinite;
  }

  @keyframes phosphor-pulse {
    0%, 100% { filter: drop-shadow(0 0 4px rgba(0, 255, 65, 0.30)); }
    50%      { filter: drop-shadow(0 0 16px rgba(0, 255, 65, 0.65)); }
  }

  @keyframes arrow-flow {
    to { stroke-dashoffset: -24; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cdat-diagram .box rect,
    .cdat-diagram .arrows path {
      animation: none !important;
    }
  }
</style>
