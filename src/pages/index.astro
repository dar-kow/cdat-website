---
import BaseLayout from '../layouts/BaseLayout.astro';
import CdatDiagram from '../components/CdatDiagram.astro';
import StatsCounter from '../components/StatsCounter.astro';
import CtaStrip from '../components/CtaStrip.astro';
import ZeroRulesSection from '../sections/ZeroRulesSection.astro';
import CodePreviewSection from '../sections/CodePreviewSection.astro';
import PomComparisonSection from '../sections/PomComparisonSection.astro';
import ProductionProofSection from '../sections/ProductionProofSection.astro';
import { tenureLabel } from '../lib/cdat-tenure';
---
<BaseLayout
  title="CDAT Pattern - Test architecture for Playwright"
  description={`Components-Data-Actions-Tests. Battle-tested across 9 production systems over ${tenureLabel}. MIT licensed.`}
>
  <section class="hero">
    <div class="hero-diagram">
      <CdatDiagram />
    </div>

    <div class="hero-text">
      <h1 class="hero-title">CDAT <span class="hero-title-accent">Pattern</span></h1>

      <p class="tagline">
        Test architecture for Playwright.<br />
        Battle-tested across <strong>9 production systems</strong> over <strong>{tenureLabel}</strong>.
      </p>

      <p class="sub-tagline">4 layers · 3 zero-rules · MIT licensed</p>

      <CtaStrip />
    </div>
  </section>

  <div class="reveal"><StatsCounter /></div>
  <div class="reveal"><ZeroRulesSection /></div>
  <div class="reveal"><CodePreviewSection /></div>
  <div class="reveal"><PomComparisonSection /></div>
  <div class="reveal"><ProductionProofSection /></div>
</BaseLayout>

<style>
  .hero {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 2.25rem 1rem 2rem;
    display: grid;
    gap: 1.5rem;
  }
  .hero > * { min-width: 0; }
  .hero-diagram { min-width: 0; }
  .hero-text { min-width: 0; }

  @media (min-width: 480px) {
    .hero { padding: 3rem 1rem; gap: 2rem; }
  }

  @media (min-width: 768px) {
    .hero {
      padding: 5rem 1.5rem 4rem;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
      align-items: center;
      /* Stretch hero to (almost) viewport - stats band lands at fold,
         Three Zero Rules waits below scroll. Mirrors sdet.it. */
      min-height: calc(85vh - 60px);
    }
  }

  .hero-title {
    font-family: var(--font-mono);
    font-size: clamp(2.5rem, 6.5vw, 4.5rem);
    line-height: 1.04;
    letter-spacing: -0.025em;
    margin: 0 0 1.5rem;
    color: var(--color-primary-500);
    font-weight: 700;
  }

  .hero-title-accent {
    color: var(--color-accent-500);
  }

  .tagline {
    font-family: var(--font-sans);
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    line-height: 1.55;
    color: #cfd8d4;
    margin: 0 0 1.25rem;
  }
  .tagline strong { color: var(--color-accent-500); font-weight: 500; }

  .sub-tagline {
    font-family: var(--font-mono);
    color: var(--color-gray-500);
    font-size: clamp(0.875rem, 1.1vw, 1rem);
    letter-spacing: 0.04em;
    margin: 0 0 2.25rem;
  }
</style>
