---
import BaseLayout from '../layouts/BaseLayout.astro';
import CdatDiagram from '../components/CdatDiagram.astro';
import StatsCounter from '../components/StatsCounter.astro';
import CtaStrip from '../components/CtaStrip.astro';
import ZeroRulesSection from '../sections/ZeroRulesSection.astro';
import ProductionProofSection from '../sections/ProductionProofSection.astro';
---
<BaseLayout
  title="CDAT Pattern — Test architecture for Playwright"
  description="Components-Data-Actions-Tests. Battle-tested across 9 production systems over 18 months. MIT licensed."
>
  <section class="hero">
    <div class="hero-diagram">
      <CdatDiagram />
    </div>

    <div class="hero-text">
      <h1 class="hero-title">CDAT <span class="hero-title-accent">Pattern</span></h1>

      <p class="tagline">
        Test architecture for Playwright. Battle-tested across
        <strong>9 production systems</strong> over <strong>18 months</strong>.
      </p>

      <p class="sub-tagline">4 layers · 3 zero-rules · MIT licensed</p>

      <CtaStrip />
      <StatsCounter />
    </div>
  </section>

  <ZeroRulesSection />
  <ProductionProofSection />
</BaseLayout>

<style>
  .hero {
    max-width: 64rem;
    margin: 0 auto;
    padding: 3rem 1rem;
    display: grid;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .hero {
      padding: 5rem 1.5rem 4rem;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
      align-items: center;
    }
  }

  .hero-title {
    font-family: var(--font-mono);
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--color-primary-500);
    font-weight: 700;
  }

  .hero-title-accent {
    color: var(--color-accent-500);
  }

  .tagline {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 2.4vw, 1.25rem);
    line-height: 1.55;
    color: #cfd8d4;
    margin: 1rem 0 0.5rem;
  }
  .tagline strong { color: var(--color-accent-500); font-weight: 600; }

  .sub-tagline {
    font-family: var(--font-mono);
    color: var(--color-gray-500);
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    margin: 0;
  }
</style>
