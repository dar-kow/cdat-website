---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocsSidebar from '../../components/DocsSidebar.astro';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((doc) => ({
    params: { slug: doc.id },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);

const wordCount = doc.body ? doc.body.split(/\s+/).filter(Boolean).length : 0;
const readingMinutes = Math.max(1, Math.round(wordCount / 200));
---
<BaseLayout
  title={`${doc.data.title} — CDAT Pattern`}
  description={doc.data.description}
>
  <div class="docs-shell">
    <DocsSidebar activeId={doc.id} />
    <article class="docs-article">
      <header class="docs-article-header">
        <p class="docs-meta">
          <span>{readingMinutes} min read</span>
          {doc.data.updated && (
            <span> · updated {doc.data.updated.toISOString().slice(0, 10)}</span>
          )}
        </p>
      </header>
      <div class="docs-prose">
        <Content />
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  .docs-shell {
    max-width: 72rem;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  /* Each shell child must constrain to its track on mobile */
  .docs-shell > * { min-width: 0; }

  .docs-article {
    min-width: 0;
    max-width: 100%;
  }

  @media (min-width: 1024px) {
    .docs-shell {
      grid-template-columns: 14rem 1fr;
    }
  }

  .docs-article-header {
    margin-bottom: 0.5rem;
  }
  .docs-meta {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-gray-500);
    margin: 0;
  }

  .docs-prose {
    font-family: var(--font-sans);
    color: #cfd8d4;
    line-height: 1.65;
    font-size: 1rem;
    max-width: 44rem;
    min-width: 0;
  }
  /* Long content (Shiki blocks, tables) must scroll inside the column,
     not blow up the viewport on mobile. */
  .docs-prose :global(pre) {
    max-width: 100%;
    overflow-x: auto;
    overscroll-behavior-x: contain;
  }
  .docs-prose :global(table) { display: block; overflow-x: auto; max-width: 100%; }
  .docs-prose :global(img) { max-width: 100%; height: auto; }
  .docs-prose :global(h1) {
    font-family: var(--font-mono);
    font-size: clamp(2rem, 5vw, 2.5rem);
    color: var(--color-primary-500);
    margin: 0 0 1.5rem;
    letter-spacing: -0.02em;
  }
  .docs-prose :global(h2) {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    color: var(--color-primary-300);
    margin: 2.5rem 0 1rem;
    border-bottom: 1px solid var(--color-primary-900);
    padding-bottom: 0.5rem;
  }
  .docs-prose :global(h3) {
    font-family: var(--font-mono);
    font-size: 1.15rem;
    color: var(--color-accent-500);
    margin: 1.75rem 0 0.5rem;
  }
  .docs-prose :global(p) { margin: 0 0 1rem; }
  .docs-prose :global(a) {
    color: var(--color-accent-500);
    text-underline-offset: 0.2em;
  }
  .docs-prose :global(ul), .docs-prose :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1rem;
  }
  .docs-prose :global(li) { margin: 0.25rem 0; }
  .docs-prose :global(table) {
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.9rem;
  }
  .docs-prose :global(th), .docs-prose :global(td) {
    border: 1px solid var(--color-primary-900);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }
  .docs-prose :global(th) {
    color: var(--color-primary-300);
    background: rgba(0, 255, 65, 0.05);
  }
  .docs-prose :global(blockquote) {
    border-left: 3px solid var(--color-accent-500);
    padding-left: 1rem;
    color: var(--color-gray-500);
    margin: 1rem 0;
    font-style: italic;
  }
  .docs-prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: rgba(0, 255, 65, 0.08);
    padding: 0.1em 0.35em;
    border-radius: 3px;
    color: var(--color-primary-300);
  }
  .docs-prose :global(pre code) {
    background: transparent;
    padding: 0;
    color: inherit;
  }
</style>
