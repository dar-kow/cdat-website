---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
const docs = (await getCollection('docs')).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout
  title="Documentation - CDAT Pattern"
  description="Architecture, zero-rules, migration guide, smart waits, anti-patterns. Everything you need to ship CDAT in production."
>
  <section class="docs-index">
    <header>
      <h1>Documentation</h1>
      <p>Six pages. Read in order or jump to what you need.</p>
    </header>

    <ol class="docs-list" role="list">
      {docs.map((d, i) => (
        <li>
          <a href={`/docs/${d.id}`} class="docs-card">
            <span class="docs-card-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <h2>{d.data.title}</h2>
              <p>{d.data.description}</p>
            </div>
          </a>
        </li>
      ))}
    </ol>
  </section>
</BaseLayout>

<style>
  .docs-index {
    max-width: 56rem;
    margin: 0 auto;
    padding: 4rem 1rem 5rem;
  }
  .docs-index header { margin-bottom: 2.5rem; text-align: center; }
  .docs-index h1 {
    font-family: var(--font-mono);
    font-size: clamp(2rem, 5vw, 2.75rem);
    color: var(--color-primary-500);
    margin: 0 0 0.5rem;
  }
  .docs-index header p {
    color: #cfd8d4;
    margin: 0;
  }
  .docs-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
  }
  .docs-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid rgba(0, 255, 65, 0.15);
    border-radius: 8px;
    background: rgba(0, 255, 65, 0.02);
    text-decoration: none;
    transition: border-color 120ms ease, background-color 120ms ease;
    align-items: center;
  }
  .docs-card:hover {
    border-color: var(--color-primary-500);
    background: rgba(0, 255, 65, 0.05);
  }
  .docs-card:focus-visible {
    outline: 2px solid var(--color-accent-500);
    outline-offset: 2px;
  }
  .docs-card-num {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    color: var(--color-accent-500);
    font-weight: 700;
  }
  .docs-card h2 {
    font-family: var(--font-mono);
    font-size: 1.15rem;
    color: var(--color-primary-300);
    margin: 0 0 0.25rem;
  }
  .docs-card p {
    color: #cfd8d4;
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  @media (prefers-reduced-motion: reduce) {
    .docs-card { transition: none; }
  }
</style>
